---
import { personal } from "../data/content";
---

<section id="contact" class="max-w-3xl mx-auto px-6 py-16 border-t border-stone-200 dark:border-stone-800">
  <h2 class="text-2xl font-light tracking-tight text-stone-900 dark:text-stone-100 mb-8">Contact</h2>
  <div class="flex flex-col gap-3">
    <a
      href={`mailto:${personal.email}`}
      class="flex items-center gap-3 text-stone-600 dark:text-stone-300 hover:text-stone-900 dark:hover:text-stone-100 transition-colors"
    >
      <span class="text-stone-400 dark:text-stone-500 text-sm w-24">Email</span>
      <span>{personal.email}</span>
    </a>
    <a
      href={personal.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 text-stone-600 dark:text-stone-300 hover:text-stone-900 dark:hover:text-stone-100 transition-colors"
    >
      <span class="text-stone-400 dark:text-stone-500 text-sm w-24">LinkedIn</span>
      <span>linkedin.com/in/rrailton</span>
    </a>
    <a
      href={personal.github}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 text-stone-600 dark:text-stone-300 hover:text-stone-900 dark:hover:text-stone-100 transition-colors"
    >
      <span class="text-stone-400 dark:text-stone-500 text-sm w-24">GitHub</span>
      <span>github.com/rrailton</span>
    </a>
  </div>
</section>
