---
import { personal } from "../data/content";
---

<section id="hero" class="max-w-3xl mx-auto px-6 py-24 flex flex-col md:flex-row items-center gap-12">
  <img
    src={personal.photo}
    alt={personal.name}
    class="w-40 h-40 rounded-full object-cover shadow-md flex-shrink-0 ring-2 ring-stone-200 dark:ring-stone-700"
    width="160"
    height="160"
  />
  <div class="animate">
    <h1 class="text-4xl font-light tracking-tight text-stone-900 dark:text-stone-100">
      {personal.name}
    </h1>
    <p class="mt-4 text-stone-600 dark:text-stone-300 max-w-lg leading-relaxed">
      {personal.bio}
    </p>
