---
import { experience } from "../data/content";
---

<section id="experience" class="max-w-3xl mx-auto px-6 py-16 border-t border-stone-200 dark:border-stone-800">
  <h2 class="text-2xl font-light tracking-tight text-stone-900 dark:text-stone-100 mb-10">Experience</h2>
  <div class="relative">
    <!-- Vertical line -->
    <div class="absolute left-0 top-0 bottom-0 w-px bg-stone-200 dark:bg-stone-700 ml-1.5"></div>

    <div class="space-y-10">
      {experience.map((job) => (
        <div class="relative pl-10">
          <!-- Dot -->
          <div class="absolute left-0 top-1.5 w-3 h-3 rounded-full bg-stone-900 dark:bg-stone-100 ring-4 ring-stone-100 dark:ring-stone-900"></div>

          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-3">
            <div>
              <h3 class="text-base font-medium text-stone-900 dark:text-stone-100">{job.title}</h3>
              <p class="text-sm text-stone-500 dark:text-stone-400">{job.company}, {job.location}</p>
            </div>
            <span class="text-sm text-stone-400 dark:text-stone-500 whitespace-nowrap">{job.start} — {job.end}</span>
          </div>

          <ul class="space-y-1.5">
            {job.bullets.map((bullet) => (
              <li class="text-sm text-stone-600 dark:text-stone-300 flex gap-2">
                <span class="text-stone-300 dark:text-stone-600 mt-0.5 flex-shrink-0">—</span>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
