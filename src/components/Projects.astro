---
import { projects } from "../data/content";
---

<section id="projects" class="max-w-3xl mx-auto px-6 py-16 border-t border-stone-200 dark:border-stone-800">
  <h2 class="text-2xl font-light tracking-tight text-stone-900 dark:text-stone-100 mb-8">Projects</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {projects.map((project) => (
      <a
        href={project.external ? project.url : `/projects/${project.slug}`}
        target={project.external ? "_blank" : undefined}
        rel={project.external ? "noopener noreferrer" : undefined}
        class="block p-6 border border-stone-200 dark:border-stone-700 rounded-xl hover:border-stone-400 dark:hover:border-stone-500 transition-colors group"
      >
        <h3 class="font-medium text-stone-900 dark:text-stone-100 group-hover:text-black dark:group-hover:text-white">
          {project.title}
        </h3>
        <p class="mt-2 text-sm text-stone-500 dark:text-stone-400">
          {project.description}
        </p>
        <span class="mt-4 inline-block text-xs text-stone-400 dark:text-stone-500 group-hover:text-stone-600 dark:group-hover:text-stone-300 transition-colors">
          {project.external ? "View on GitHub" : "Read more"} &rarr;
        </span>
      </a>
    ))}
  </div>
</section>
